# Environment configuration for course-grabbing scripts
# Copy this file to .env and fill in your real values.

# Educational administration system base URL
BASE_URL=http://210.38.162.118

# Default account for single-user scrapers (get_course_json.py)
# Leave empty if you prefer to use accounts.json
SINGLE_USERNAME=
SINGLE_PASSWORD=

# Request concurrency settings
LOGIN_WORKERS=3
GRAB_DELAY_MIN=0.8
GRAB_DELAY_MAX=2.0
GRAB_TIMEOUT=5

# Cookie encryption: set to true and provide a key to enable Fernet encryption
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_COOKIES=false
COOKIE_KEY=

# Default User-Agent used by request-based scripts
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.0
